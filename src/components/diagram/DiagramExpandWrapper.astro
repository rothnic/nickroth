---
// DiagramExpandWrapper - Reusable wrapper for diagram expand/zoom/pan functionality
// Wraps any diagram (Excalidraw or Mermaid) with toolbar and modal
export interface Props {
  alt: string;
  caption?: string;
}

const { alt, caption } = Astro.props;
const uniqueId = Math.random().toString(36).slice(2, 11);
---

<figure class="diagram-figure" data-diagram-id={uniqueId}>
  <div class="diagram-toolbar">
    <span class="diagram-label">{alt}</span>
    <button 
      class="diagram-expand-btn" 
      type="button" 
      aria-label="Expand diagram to full screen"
      data-expand-btn
    >
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M15 3h6v6M9 21H3v-6M21 3l-7 7M3 21l7-7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      <span>Expand</span>
    </button>
  </div>
  
  <div 
    class="diagram-container" 
    data-diagram-wrapper
    aria-label={alt}
  >
    <slot />
  </div>
  
  {caption && (
    <figcaption class="diagram-caption">{caption}</figcaption>
  )}
</figure>

<div class="diagram-modal" data-modal-for={uniqueId} aria-hidden="true">
  <div class="diagram-modal-backdrop"></div>
  <div class="diagram-modal-content">
    <div class="diagram-modal-header">
      <button class="diagram-modal-close" type="button" aria-label="Close">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M18 6L6 18M6 6l12 12" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
      <span class="diagram-modal-title">{alt}</span>
      <div class="diagram-modal-zoom-controls">
        <button class="diagram-modal-zoom-btn zoom-out" type="button" aria-label="Zoom out">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M5 12h14" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
          </svg>
        </button>
        <span class="zoom-level">100%</span>
        <button class="diagram-modal-zoom-btn zoom-in" type="button" aria-label="Zoom in">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M5 12h14M12 5v14" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
          </svg>
        </button>
        <button class="diagram-modal-zoom-btn zoom-reset" type="button" aria-label="Reset zoom">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 12" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
      </div>
    </div>
    <div class="diagram-modal-body">
      <div class="diagram-modal-svg-wrapper">
        <div class="diagram-modal-svg-container"></div>
      </div>
    </div>
    
    <div class="diagram-modal-footer">
      <p class="diagram-modal-hint">Pinch to zoom - Drag to pan</p>
    </div>
  </div>
</div>

<script>
  (function() {
    function initDiagramWrapper(figure) {
      const wrapperId = figure.dataset.diagramId;
      const wrapper = figure.querySelector('[data-diagram-wrapper]');
      const expandBtn = figure.querySelector('[data-expand-btn]');
      const modal = document.querySelector(`[data-modal-for="${wrapperId}"]`);
      
      if (!wrapper || !expandBtn || !modal) return;
      
      const svgWrapper = modal.querySelector('.diagram-modal-svg-wrapper') as HTMLElement | null;
      const container = modal.querySelector('.diagram-modal-svg-container') as HTMLElement | null;
      const zoomLevelEl = modal.querySelector('.zoom-level');
      const closeBtn = modal.querySelector('.diagram-modal-close');
      const zoomInBtn = modal.querySelector('.zoom-in');
      const zoomOutBtn = modal.querySelector('.zoom-out');
      const zoomResetBtn = modal.querySelector('.zoom-reset');
      
      // Start at scale 0.25 (original size before expanding)
      // SVG has 4x intrinsic size, so 0.25 scale = original size
      // Zoom range: 0.25 (original) to 1.0 (4x larger)
      let scale = 0.25;
      let translateX = 0;
      let translateY = 0;
      let isDragging = false;
      let lastX = 0;
      let lastY = 0;
      let lastPinchDistance = 0;
      let rafId = null;
      let debounceTimer = null;
      
      // Store reference to original parent for moving back
      let originalParent: HTMLElement | null = null;
      
      // Set SVG to viewport size so 100% zoom fills the modal body
      function setupSvgForScaling() {
        const svg = container?.querySelector('svg');
        if (!svg || !container) return;
        
        // Get the modal body dimensions (viewport for the diagram)
        const modalBody = container.closest('.diagram-modal-body') as HTMLElement;
        if (!modalBody) return;
        
        const viewportWidth = modalBody.clientWidth;
        const viewportHeight = modalBody.clientHeight;
        
        // Store original viewBox if present
        const originalViewBox = svg.getAttribute('viewBox');
        if (originalViewBox && !svg.dataset.originalViewBox) {
          svg.dataset.originalViewBox = originalViewBox;
        }
        
        // Get original SVG dimensions from viewBox or bbox
        let originalWidth = 0;
        let originalHeight = 0;
        
        if (originalViewBox) {
          const parts = originalViewBox.split(' ').map(Number);
          originalWidth = parts[2];
          originalHeight = parts[3];
        } else {
          // Get bounding box of SVG content
          const bbox = (svg as SVGSVGElement).getBBox?.();
          if (bbox) {
            originalWidth = bbox.width;
            originalHeight = bbox.height;
          } else {
            // Fallback to current size
            const rect = svg.getBoundingClientRect();
            originalWidth = rect.width;
            originalHeight = rect.height;
          }
        }
        
        if (!originalWidth || !originalHeight) return;
        
        // Calculate scale to fit viewport at 100% zoom
        const scaleX = viewportWidth / originalWidth;
        const scaleY = viewportHeight / originalHeight;
        const fitScale = Math.min(scaleX, scaleY) * 0.9; // 90% to leave some margin
        
        // Set SVG width/height to fill viewport at 100% zoom
        const targetWidth = originalWidth * fitScale;
        const targetHeight = originalHeight * fitScale;
        
        svg.setAttribute('width', String(targetWidth));
        svg.setAttribute('height', String(targetHeight));
        
        // Ensure viewBox matches original dimensions for proper scaling
        if (!svg.getAttribute('viewBox')) {
          svg.setAttribute('viewBox', `0 0 ${originalWidth} ${originalHeight}`);
        }
        
        // Store the fit scale for reference
        svg.dataset.fitScale = String(fitScale);
      }
      
      function open() {
        const svg = wrapper.querySelector('svg');
        if (!svg || !container) return;
        
        // Store original parent so we can move SVG back later
        originalParent = svg.parentElement as HTMLElement;
        if (!originalParent) return;
        
        // Get original dimensions BEFORE moving
        const originalRect = svg.getBoundingClientRect();
        const originalWidth = originalRect.width;
        const originalHeight = originalRect.height;
        
        // Move the actual SVG to the modal (don't clone it)
        // This preserves all CSS classes and styling context
        container.innerHTML = '';
        container.appendChild(svg);
        
        // CRITICAL: Set SVG to LARGE intrinsic size so we can zoom in without fuzziness
        // We set intrinsic size to 4x original, then scale it DOWN to 1x for the initial view
        // This way when user zooms in to 2x, 3x, 4x, it's still crisp (scaling DOWN from 4x)
        const scaleFactor = 4;
        const baseWidth = originalWidth > 0 ? originalWidth : 800;
        const baseHeight = originalHeight > 0 ? originalHeight : 600;
        const largeWidth = baseWidth * scaleFactor;
        const largeHeight = baseHeight * scaleFactor;
        
        // Store original dimensions
        svg.dataset.originalWidth = String(baseWidth);
        svg.dataset.originalHeight = String(baseHeight);
        svg.dataset.scaleFactor = String(scaleFactor);
        
        // Set the large intrinsic size via attributes (for crisp rendering)
        // But DON'T set inline styles that would expand the container
        // CSS max-width/max-height will constrain the display size
        svg.setAttribute('width', String(largeWidth));
        svg.setAttribute('height', String(largeHeight));
        
        // Explicitly clear any inline styles that might interfere
        svg.style.width = '';
        svg.style.height = '';
        
        // Set viewBox to original dimensions so 1 scale unit = original size
        if (!svg.getAttribute('viewBox')) {
          svg.setAttribute('viewBox', `0 0 ${baseWidth} ${baseHeight}`);
        }
        
        // Force a reflow to ensure the SVG renders
        void svg.offsetHeight;
        
        requestAnimationFrame(() => {
          modal.classList.add('active');
          modal.setAttribute('aria-hidden', 'false');
          document.body.style.overflow = 'hidden';
        });
        
        reset();
      }
      
      function close() {
        const svg = container?.querySelector('svg');
        if (svg && originalParent) {
          // Reset container transform before moving back so diagram returns to normal size
          if (container) {
            container.style.transform = '';
          }
          
          // Restore original SVG dimensions
          svg.removeAttribute('width');
          svg.removeAttribute('height');
          svg.style.width = '';
          svg.style.height = '';
          delete svg.dataset.originalWidth;
          delete svg.dataset.originalHeight;
          
          // Move SVG back to its original parent container
          originalParent.appendChild(svg);
        }
        
        modal.classList.remove('active');
        modal.setAttribute('aria-hidden', 'true');
        document.body.style.overflow = '';
      }
      
      function zoom(delta) {
        // Allow zoom from 0.25 (original size) to 1.0 (4x zoomed in)
        // 0.25 = 25% of intrinsic = original size
        // 1.0 = 100% of intrinsic = 4x original size
        scale = Math.max(0.25, Math.min(1.0, scale + delta));
        scheduleUpdate();
      }
      
      function reset() {
        // Reset to 0.25 (original size before expanding)
        scale = 0.25;
        translateX = 0;
        translateY = 0;
        scheduleUpdate();
      }
      
      function scheduleUpdate() {
        if (rafId) return;
        rafId = requestAnimationFrame(() => {
          updateTransform();
          rafId = null;
        });
      }
      
      function updateTransform() {
        if (container) {
          // Container is positioned at top: 50%, left: 50%
          // Translate -50% to center, then apply pan and scale
          container.style.transform = `translate(-50%, -50%) translate3d(${translateX}px, ${translateY}px, 0) scale(${scale})`;
        }
        if (zoomLevelEl) {
          zoomLevelEl.textContent = `${Math.round(scale * 100)}%`;
        }
      }
      
      function handleTouchStart(e) {
        if (e.touches.length === 1) {
          isDragging = true;
          lastX = e.touches[0].clientX;
          lastY = e.touches[0].clientY;
        } else if (e.touches.length === 2) {
          lastPinchDistance = Math.hypot(
            e.touches[0].clientX - e.touches[1].clientX,
            e.touches[0].clientY - e.touches[1].clientY
          );
        }
      }
      
      function handleTouchMove(e) {
        e.preventDefault();
        
        if (e.touches.length === 1 && isDragging) {
          const dx = e.touches[0].clientX - lastX;
          const dy = e.touches[0].clientY - lastY;
          translateX += dx;
          translateY += dy;
          lastX = e.touches[0].clientX;
          lastY = e.touches[0].clientY;
          scheduleUpdate();
        } else if (e.touches.length === 2) {
          const distance = Math.hypot(
            e.touches[0].clientX - e.touches[1].clientX,
            e.touches[0].clientY - e.touches[1].clientY
          );
          const delta = (distance - lastPinchDistance) / 200;
          scale = Math.max(0.25, Math.min(1.0, scale + delta));
          lastPinchDistance = distance;
          scheduleUpdate();
        }
      }
      
      function handleTouchEnd() {
        isDragging = false;
      }
      
      function handleMouseDown(e) {
        isDragging = true;
        lastX = e.clientX;
        lastY = e.clientY;
        if (container instanceof HTMLElement) container.style.cursor = 'grabbing';
      }
      
      function handleMouseMove(e) {
        if (!isDragging) return;
        const dx = e.clientX - lastX;
        const dy = e.clientY - lastY;
        translateX += dx;
        translateY += dy;
        lastX = e.clientX;
        lastY = e.clientY;
        scheduleUpdate();
      }
      
      function handleMouseUp() {
        isDragging = false;
        if (container instanceof HTMLElement) container.style.cursor = 'grab';
      }
      
      function handleWheel(e) {
        e.preventDefault();
        const delta = e.deltaY > 0 ? -0.1 : 0.1;
        zoom(delta);
      }
      
      expandBtn.addEventListener('click', open);
      closeBtn?.addEventListener('click', close);
      modal.querySelector('.diagram-modal-backdrop')?.addEventListener('click', close);
      zoomInBtn?.addEventListener('click', () => zoom(0.1));
      zoomOutBtn?.addEventListener('click', () => zoom(-0.1));
      zoomResetBtn?.addEventListener('click', reset);
      
      container?.addEventListener('touchstart', handleTouchStart, { passive: false });
      container?.addEventListener('touchmove', handleTouchMove, { passive: false });
      container?.addEventListener('touchend', handleTouchEnd);
      
      container?.addEventListener('mousedown', handleMouseDown);
      document.addEventListener('mousemove', handleMouseMove);
      document.addEventListener('mouseup', handleMouseUp);
      
      container?.addEventListener('wheel', handleWheel, { passive: false });
      
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') close();
      });
    }
    
    function initAllDiagrams() {
      document.querySelectorAll('[data-diagram-id]').forEach(initDiagramWrapper);
    }
    
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initAllDiagrams);
    } else {
      initAllDiagrams();
    }
    
    document.addEventListener('astro:page-load', initAllDiagrams);
  })();
</script>

<style>
  .diagram-figure {
    margin: 2rem auto;
    border: 2px solid var(--nr-border-color);
    background: var(--color-base-100);
    box-shadow: var(--nr-shadow-sm);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    max-width: 100%;
  }

  .diagram-toolbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 8px 12px;
    background: var(--color-base-200);
    border-bottom: 2px solid var(--nr-border-color);
    gap: 12px;
  }

  .diagram-label {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-base-content);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .diagram-expand-btn {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 6px 12px;
    background: var(--color-base-100);
    border: 2px solid var(--nr-border-color);
    border-radius: 4px;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-base-content);
    cursor: pointer;
    box-shadow: var(--nr-shadow-sm);
    transition: all 0.15s ease;
    flex-shrink: 0;
  }

  .diagram-expand-btn:hover {
    background: var(--color-base-300);
    transform: translateY(-1px);
    box-shadow: var(--nr-shadow-md);
  }

  .diagram-expand-btn svg {
    flex-shrink: 0;
  }

  .diagram-container {
    position: relative;
    overflow: hidden;
    display: flex;
    justify-content: center;
    align-items: center;
    max-width: 100%;
  }

  .diagram-container > :global(svg) {
    height: auto;
    width: 100%;
    max-width: 100%;
    display: block;
    will-change: transform;
  }

  .diagram-caption {
    padding: 12px;
    font-size: 0.875rem;
    color: var(--color-base-content);
    text-align: center;
    font-style: italic;
    border-top: 2px solid var(--nr-border-color);
    background: var(--color-base-200);
  }

  .diagram-modal {
    position: fixed;
    inset: 0;
    z-index: 1000;
    display: none;
    flex-direction: column;
  }

  .diagram-modal.active {
    display: flex;
  }

  .diagram-modal-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.85);
    backdrop-filter: blur(4px);
  }

  .diagram-modal-content {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    height: 100%;
    background: var(--color-base-100);
  }

  .diagram-modal-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 12px 16px;
    border-bottom: 2px solid var(--nr-border-color);
    background: var(--color-base-200);
    gap: 16px;
    position: relative;
    z-index: 10;
  }

  .diagram-modal-close {
    width: 40px;
    height: 40px;
    background: none;
    border: 2px solid var(--nr-border-color);
    border-radius: 4px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    color: var(--color-base-content);
    flex-shrink: 0;
  }

  .diagram-modal-close:hover {
    background: var(--color-base-300);
  }

  .diagram-modal-title {
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-base-content);
    flex: 1;
    text-align: center;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .diagram-modal-zoom-controls {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-shrink: 0;
  }

  .diagram-modal-zoom-btn {
    width: 36px;
    height: 36px;
    background: var(--color-base-100);
    border: 2px solid var(--nr-border-color);
    border-radius: 4px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    color: var(--color-base-content);
  }

  .diagram-modal-zoom-btn:hover {
    background: var(--color-base-300);
  }

  .zoom-level {
    font-size: 14px;
    font-weight: 500;
    color: var(--color-base-content);
    min-width: 50px;
    text-align: center;
    font-family: var(--font-mono), monospace;
  }

  .diagram-modal-body {
    flex: 1;
    overflow: visible;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-base-100);
    cursor: grab;
    touch-action: none;
  }

  .diagram-modal-body:active {
    cursor: grabbing;
  }

  .diagram-modal-svg-wrapper {
    /* Container for positioning */
    position: relative;
    width: 100%;
    height: 100%;
    overflow: visible;
  }

  .diagram-modal-svg-container {
    /* Positioned absolutely to not affect modal body size */
    position: absolute;
    top: 50%;
    left: 50%;
    /* GPU acceleration for smooth panning */
    transform-style: preserve-3d;
    backface-visibility: hidden;
    will-change: transform;
  }


  .diagram-modal-svg-container :global(svg) {
    /* Use explicit width/height from attributes - allow SVG to be larger than viewport */
    /* max-width/max-height removed to allow zooming in beyond viewport */
    /* Prevent fuzzy rendering when scaled */
    shape-rendering: geometricPrecision;
    vector-effect: non-scaling-stroke;
    /* Ensure SVG uses its intrinsic size */
    width: auto;
    height: auto;
  }

  .diagram-modal-footer {
    padding: 12px 16px;
    border-top: 2px solid var(--nr-border-color);
    background: var(--color-base-200);
    text-align: center;
  }

  .diagram-modal-hint {
    margin: 0;
    font-size: 13px;
    color: var(--color-base-content);
    opacity: 0.7;
  }

  @media (min-width: 768px) {
    .diagram-modal-content {
      margin: 5vh auto;
      width: 90vw;
      height: 90vh;
      max-width: 1200px;
      border-radius: 8px;
      border: 3px solid var(--nr-border-color);
      box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
    }
  }
</style>