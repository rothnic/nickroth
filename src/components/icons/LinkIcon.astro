---
/**
 * LinkIcon Component
 * 
 * A small link/chain icon for heading anchor links.
 * Used to indicate that clicking will copy the section link.
 * 
 * Usage:
 * <LinkIcon class="w-4 h-4" />
 */

interface Props {
  class?: string;
}

const { class: className = "w-4 h-4" } = Astro.props;
---

<svg
  class={className}
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="2"
  stroke-linecap="round"
  stroke-linejoin="round"
  aria-hidden="true"
>
  <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"></path>
  <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"></path>
</svg>
